{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Streamlit: app",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "streamlit_app.py"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "CLI: query sample",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/Untitled-1.py",
      "args": [
        "--query",
        "deep learning",
        "--rows",
        "10",
        "--filter",
        "type=journal-article",
        "--format",
        "json",
        "--out",
        "outputs/vscode_sample.json"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
